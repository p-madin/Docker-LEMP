<?xml version="1.0" encoding="UTF-8"?>
<testSuite>
  <name>LEMP Stack Integrated Tests</name>
  <testGroup>
    <!-- Original Login Test (Updated to use /) -->
    <test>
      <index>1</index>
      <name>Basic Login/Logout</name>
      <description>Verify admin login and logout</description>
      <stepList>
        <step>
          <action>NavigateTo</action>
          <url>/</url>
        </step>
        <step>
          <action>FillForm</action>
          <selector>#loginFormComponent</selector>
          <parameters>
            <parameter><name>username</name><value>Stack</value></parameter>
            <parameter><name>password</name><value>Stack</value></parameter>
          </parameters>
          <submit>true</submit>
        </step>
        <step>
          <action>AssertText</action>
          <selector>#loginWidgetSummary</selector>
          <expected>
            <contains>You are already signed in</contains>
          </expected>
        </step>
        <step>
          <action>Click</action>
          <selector>logout</selector>
        </step>
      </stepList>
    </test>

    <!-- Merged Lifecycle Test -->
    <test>
      <index>8</index>
      <name>User Lifecycle Management</name>
      <description>Register, verify as admin, and login as new user</description>
      
      <stepList>
        <step>
          <action>NavigateTo</action>
          <url>/</url>
        </step>
        <step>
          <action>FillForm</action>
          <selector>#registerFormComponent</selector>
          <parameters>
            <parameter><name>username</name><value>LifecycleUser</value></parameter>
            <parameter><name>password</name><value>Pass123!</value></parameter>
            <parameter><name>confirm_password</name><value>Pass123!</value></parameter>
            <parameter><name>name</name><value>LC User</value></parameter>
            <parameter><name>age</name><value>25</value></parameter>
            <parameter><name>city</name><value>Test City</value></parameter>
            <parameter><name>email</name><value>lc@example.com</value></parameter>
          </parameters>
          <submit>true</submit>
          <expected>
            <statusCode>200</statusCode>
          </expected>
        </step>

        <!-- Login as admin to verify the new user -->
        <step>
          <action>NavigateTo</action>
          <url>/</url>
        </step>
        <step>
          <action>FillForm</action>
          <selector>#loginFormComponent</selector>
          <parameters>
            <parameter><name>username</name><value>Stack</value></parameter>
            <parameter><name>password</name><value>Stack</value></parameter>
          </parameters>
          <submit>true</submit>
        </step>

        <!-- Navigate to account management and edit the new user's row -->
        <step>
          <action>NavigateTo</action>
          <url>/account_management</url>
        </step>
        <step>
          <action>Click</action>
          <selector>.form_hyperlink[id^="edit-user-LifecycleUser"]</selector>
        </step>
        <step>
          <action>FillForm</action>
          <selector>#editUserFormComponent</selector>
          <parameters>
            <parameter><name>verified_status</name><value>checked</value></parameter>
          </parameters>
          <submit>true</submit>
        </step>

        <!-- Logout and login as the newly verified user -->
        <step>
          <action>Click</action>
          <selector>logout</selector>
        </step>
        <step>
          <action>FillForm</action>
          <selector>#loginFormComponent</selector>
          <parameters>
            <parameter><name>username</name><value>LifecycleUser</value></parameter>
            <parameter><name>password</name><value>Pass123!</value></parameter>
          </parameters>
          <submit>true</submit>
        </step>
        <step>
          <action>AssertText</action>
          <selector>#loginWidgetSummary</selector>
          <expected>
            <contains>You are already signed in</contains>
          </expected>
        </step>
      </stepList>
    </test>
    
    <!-- Phase 3 Regression Audit -->
    <test>
      <index>9</index>
      <name>Phase 3 Regression Audit</name>
      <description>Audit Hyperlink targeting, Field Value collisions, and Checkbox persistence</description>
      
      <stepList>
        <!-- 1. Login as Admin -->
        <step>
          <action>NavigateTo</action>
          <url>/</url>
        </step>
        <step>
          <action>FillForm</action>
          <selector>#loginFormComponent</selector>
          <parameters>
            <parameter><name>username</name><value>Stack</value></parameter>
            <parameter><name>password</name><value>Stack</value></parameter>
          </parameters>
          <submit>true</submit>
        </step>

        <!-- 2. Verify that clicking Edit for Stack_Two opens the correct edit page -->
        <step>
          <action>NavigateTo</action>
          <url>/account_management</url>
        </step>=
        <step>
          <action>Click</action>
          <selector>.form_hyperlink[id^="edit-user-Stack_Two"]</selector>
        </step>
        <step>
          <action>AssertText</action>
          <expected>
            <contains>Editing User: Stack_Two</contains>
            <contains>value="Stack_Two"</contains>
          </expected>
        </step>

        <!-- 3. Verify Checkbox Uncheck Logic — submit with verified_status unchecked -->
        <step>
          <action>FillForm</action>
          <selector>#editUserFormComponent</selector>
          <parameters>
            <parameter><name>verified_status</name><value>unchecked</value></parameter>
          </parameters>
          <submit>true</submit>
        </step>
        <!-- Confirm the status is now shown as unverified in the list -->
        <step>
          <action>NavigateTo</action>
          <url>/account_management</url>
        </step>
        <step>
          <action>AssertText</action>
          <expected>
            <contains>Pending</contains>
          </expected>
        </step>

        <!-- 4. Restore Status (Clean up) — re-check verified for Stack_Two -->
        <step>
          <action>Click</action>
          <selector>.form_hyperlink[id^="edit-user-Stack_Two"]</selector>
        </step>
        <step>
          <action>FillForm</action>
          <selector>#editUserFormComponent</selector>
          <parameters>
            <parameter><name>verified_status</name><value>checked</value></parameter>
          </parameters>
          <submit>true</submit>
        </step>
        
        <step>
          <action>Click</action>
          <selector>logout</selector>
        </step>
      </stepList>
    </test>

    <!-- Test 10: Navbar Management Lifecycle -->
    <test>
      <index>10</index>
      <name>Navbar Management Lifecycle</name>
      <description>Update/Revert existing item and Create/Delete new item</description>
      <stepList>
        <step>
          <action>NavigateTo</action>
          <url>/</url>
        </step>
        <step>
          <action>FillForm</action>
          <selector>#loginFormComponent</selector>
          <parameters>
            <parameter><name>username</name><value>Stack</value></parameter>
            <parameter><name>password</name><value>Stack</value></parameter>
          </parameters>
          <submit>true</submit>
        </step>
        
        <!-- 1. Update Dashboard label & revert -->
        <step>
          <action>NavigateTo</action>
          <url>/navbar_management</url>
        </step>
        <step>
          <action>Click</action>
          <selector>.form_hyperlink[id^="edit-navbar-/dashboard"]</selector>
        </step>
        <step>
          <action>FillForm</action>
          <selector>#editNavbarFormComponent</selector>
          <parameters>
            <parameter><name>nbText</name><value>Dashboard Updated</value></parameter>
          </parameters>
          <submit>true</submit>
        </step>
        <step>
          <action>AssertText</action>
          <expected>
            <contains>Dashboard Updated</contains>
          </expected>
        </step>
        <step>
          <action>Click</action>
          <selector>.form_hyperlink[id^="edit-navbar-/dashboard"]</selector>
        </step>
        <step>
          <action>FillForm</action>
          <selector>#editNavbarFormComponent</selector>
          <parameters>
            <parameter><name>nbText</name><value>Dashboard</value></parameter>
          </parameters>
          <submit>true</submit>
        </step>
        
        <!-- 2. Create a temporary navbar item & delete it -->
        <step>
          <action>Click</action>
          <selector>#nav_Create_New_Navbar_Item</selector>
        </step>
        <step>
          <action>FillForm</action>
          <selector>#editNavbarFormComponent</selector>
          <parameters>
            <parameter><name>nbText</name><value>Temporary Test Link</value></parameter>
            <parameter><name>nbPath</name><value>/test_path</value></parameter>
            <parameter><name>nbControllerClass</name><value>DashboardController</value></parameter>
            <parameter><name>nbOrder</name><value>99</value></parameter>
          </parameters>
          <submit>true</submit>
        </step>
        <step>
          <action>AssertText</action>
          <expected>
            <contains>Temporary Test Link</contains>
          </expected>
        </step>
        <step>
          <action>Click</action>
          <selector>.form_hyperlink[id^="delete-navbar-/test_path"]</selector>
        </step>
        <step>
          <action>AssertText</action>
          <expected>
            <not_contains>Temporary Test Link</not_contains>
          </expected>
        </step>
        
        <!-- 3. Verify Undo/Redo cycle on the Delete action (Event Sourcing State Assurance) -->
        <step>
          <action>Click</action>
          <selector>.undo-button</selector>
        </step>
        <step>
          <action>AssertText</action>
          <expected>
            <contains>Temporary Test Link</contains>
          </expected>
        </step>
        <step>
          <action>Click</action>
          <selector>.redo-button</selector>
        </step>
        <step>
          <action>AssertText</action>
          <expected>
            <not_contains>Temporary Test Link</not_contains>
          </expected>
        </step>
        <step>
          <action>Click</action>
          <selector>.undo-button</selector>
        </step>
        <step>
          <action>AssertText</action>
          <expected>
            <contains>Temporary Test Link</contains>
          </expected>
        </step>
        
        <!-- 4. Final Tear Down (Manual Delete to ensure environment is clean) -->
        <step>
          <action>Click</action>
          <selector>.form_hyperlink[id^="delete-navbar-/test_path"]</selector>
        </step>
        <step>
          <action>AssertText</action>
          <expected>
            <not_contains>Temporary Test Link</not_contains>
          </expected>
        </step>
        
        <step>
          <action>Click</action>
          <selector>logout</selector>
        </step>
      </stepList>
    </test>

    <!-- Test 11: Form & Field Management Lifecycle -->
